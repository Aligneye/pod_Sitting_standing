# Secrets and local credentials
# Keep anything that could contain machine-specific or sensitive data out of git.
.env
.env.*
secrets.*
credentials.*
*.pem
*.key

# Private local engineering knowledge base
# This is intentionally machine-local and must never be committed.
PROJECT_PRIVATE/

# PlatformIO build and dependency caches
# These are generated by the firmware toolchain and can be rebuilt locally.
.pio/
.pioenvs/
.piolibdeps/
firmware/.pio/

# Python bytecode, virtual environments, and test/tooling caches
# These are machine-local and always reproducible.
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.venv/
venv/

# Jupyter and notebook checkpoints
.ipynb_checkpoints/

# VS Code local state
# Keep shared workspace configuration files tracked, but ignore per-user caches.
.claude/
.vscode/*.db
.vscode/*.db-*
.vscode/ipch/
.vscode/.browse.c_cpp.db*
.vscode/*.log

# Operating system metadata
.DS_Store
Thumbs.db
desktop.ini

# Generated analysis outputs
# These can be recreated from the raw datasets, so we do not need them in git.
plots/
debug/
reports/
analysis/transition_alignment/*.html
analysis/transition_alignment/*.csv
analysis/transition_alignment/*.md
analysis/transition_alignment/*.json
analysis/transition_alignment/plots/
analysis/transition_alignment/reports/
analysis/transition_alignment/dataset/
analysis/transition_alignment/models/
analysis/transition_alignment/__pycache__/
analysis/transition_alignment/**/*.html
analysis/transition_alignment/**/*.csv
analysis/transition_alignment/**/*.json

# Classification experiment outputs
# Dataset artifacts, reports, plots, and saved models are reproducible.
datasets/labels/
datasets/processed/
datasets/windows/
analysis/transition_classification/dataset/
analysis/transition_classification/plots/
analysis/transition_classification/reports/
analysis/transition_classification/models/
analysis/transition_classification/__pycache__/
analysis/transition_classification/**/*.csv
analysis/transition_classification/**/*.png
analysis/transition_classification/**/*.json
analysis/event_analysis/reports/

# Legacy transition overlay outputs
# These visualizations are reproducible from the raw session CSVs.
analysis/transition_overlays/*.html
analysis/transition_overlays/*.md
analysis/transition_overlays/*.csv

# Generic temporary, log, and backup files
*.log
*.tmp
*.temp
*.bak
*.orig
*~

# Build products from common toolchains
build/
dist/
site/
coverage/

# Do not ignore source, documentation, raw datasets, metadata, firmware, or
# manually curated reference assets. Those are part of the project history.
